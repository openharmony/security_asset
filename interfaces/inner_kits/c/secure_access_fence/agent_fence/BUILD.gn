import("//build/ohos.gni")

config("saf_client_config") {
  include_dirs = [
    "inc",
  ]
}

ohos_shared_library("saf_agent_fence") {
  sources = [ "../../../../../frameworks/secure_access_fence/inner_api/agent_fence/src/saf_agent_fence.cpp" ]

  public_configs = [
    ":saf_client_config",
    "../../../../../frameworks/secure_access_fence/inner_api/ipc:saf_idl_config",
  ]

  include_dirs = [
    "inc",
    "../../../../../frameworks/secure_access_fence/inner_api/agent_fence/inc",
    "../../../../../frameworks/secure_access_fence/inner_api/ipc",
    "../../../../../frameworks/secure_access_fence/os_dependency/log/inc",
  ]

  deps = [
    "../../../../../frameworks/secure_access_fence/inner_api/ipc:secure_access_fence_proxy",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_single",
    "samgr:samgr_proxy",
  ]

  sanitize = {
    integer_overflow = true
    cfi = true
    debug = false
    cfi_cross_dso = true
    boundary_sanitize = true
    ubsan = true
  }

  innerapi_tags = [ "platformsdk" ]

  branch_protector_ret = "pac_ret"

  subsystem_name = "security"
  part_name = "asset"
}